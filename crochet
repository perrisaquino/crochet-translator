#!/bin/bash
# crochet — start the Crochet Translator + Photo-to-Amigurumi server
#
# Install globally: ln -sf "$(pwd)/crochet" /usr/local/bin/crochet

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
VENV="$SCRIPT_DIR/.venv"
PORT="${CROCHET_PORT:-8008}"
URL="http://localhost:$PORT"

if [ ! -d "$VENV" ]; then
  echo "Error: no .venv found at $SCRIPT_DIR/.venv"
  echo "Run: python3 -m venv .venv && .venv/bin/pip install -r requirements.txt"
  exit 1
fi

# Check if port is already in use
if lsof -i ":$PORT" -sTCP:LISTEN -t &>/dev/null; then
  echo "Error: port $PORT is already in use"
  echo "Kill it or set a different port: CROCHET_PORT=8080 crochet"
  exit 1
fi

echo "Crochet Translator"
echo "  $URL"
echo "  Ctrl+C to stop"
echo ""

# Open browser once the server is actually responding
(until curl -sf "$URL" > /dev/null 2>&1; do sleep 0.3; done && open "$URL") &

cd "$SCRIPT_DIR"
exec "$VENV/bin/uvicorn" server:app --host 0.0.0.0 --port "$PORT"
